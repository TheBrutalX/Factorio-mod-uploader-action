{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@phases/*": ["./src/phases/*"],
      "@errors/*": ["./src/errors/*"],
      "@interfaces/*": ["./src/interfaces/*"],
      "@services/*": ["./src/services/*"],
      "@types/*": ["./src/types/*"],
      "@utils/*": ["./src/utils/*"],
      "@constants": ["./src/constants"]
    }
  },
  "include": ["src"],
  "ts-node": {
    "esm": true
  }
}